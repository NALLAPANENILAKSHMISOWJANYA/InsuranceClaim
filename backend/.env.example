# Insurance Claim Pre-Assurance – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.

# ── Application ────────────────────────────────────────────────────────────────
APP_NAME="Insurance Claim Pre-Assurance"
VERSION="1.0.0"
DEBUG=false

# ── Database ───────────────────────────────────────────────────────────────────
# SQLite (sandbox default)
DATABASE_URL=sqlite:///./claimsense.db

# PostgreSQL (production — uncomment and fill in)
# DATABASE_URL=postgresql+psycopg2://user:password@host:5432/claimsense

# ── LLM Provider (external API – choose one) ──────────────────────────────────
LLM_PROVIDER=anthropic
LLM_API_KEY=your_api_key_here
LLM_MODEL=claude-3-haiku-20240307

# ── Fraud Thresholds ───────────────────────────────────────────────────────────
FRAUD_HIGH_VALUE_THRESHOLD=500000.0
FRAUD_RAPID_RECLAIM_DAYS=90

# ── Upload Limits ─────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=20
